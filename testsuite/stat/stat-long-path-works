# FEATURE: CONFIG_FEATURE_LONG_PATHS

BASEDIR=c:/temp/stat_longpath_test$$
D=longdirname_12345

DEEPPATH=$BASEDIR
for i in $(seq 15)
do
	DEEPPATH=$DEEPPATH/$D
done
mkdir -p $DEEPPATH && touch $DEEPPATH/testfile.txt || \
	{ echo "directory creation failed"; rm -rf "$BASEDIR"; exit 1; }

busybox stat "$DEEPPATH/testfile.txt" > /dev/null 2>&1 || { echo "stat failed"; rm -rf $BASEDIR; exit 1; }
busybox stat "$DEEPPATH" > /dev/null 2>&1 || { echo "stat failed on dir"; rm -rf "$BASEDIR"; exit 1; }
busybox rm -rf "$BASEDIR"
